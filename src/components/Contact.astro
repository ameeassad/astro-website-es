---
import ContactForm from './ContactForm';
import PineSmall from './PineSmall.astro';
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="section" id="contact">
  <div class="section-inner">
    <p class="section-label reveal">{t.contactLabel}</p>
    <h2 class="section-title reveal" style="transition-delay:0.1s">
      {t.contactTitle[0]}<em>{t.contactTitle[1]}</em>
    </h2>

    <div class="contact-layout">
      <!-- Interactive contact form (React island) -->
      <ContactForm t={t} client:visible />

      <!-- Contact info (static) -->
      <div class="reveal" style="transition-delay:0.3s">
        <div class="contact-info">
          <h3>{t.contactTitle[0]}{t.contactTitle[1]}</h3>
          <div class="contact-detail">
            <strong>Address</strong>
            {t.address}
          </div>
          <div class="contact-detail">
            <strong>Email</strong>
            <a href={`mailto:${t.email}`}>{t.email}</a>
          </div>
          <div class="contact-detail">
            <strong>Phone / WhatsApp</strong>
            <a href={`tel:${t.phone}`}>{t.phone}</a>
          </div>
        </div>

        <iframe
          src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d660.4960942607213!2d0.13417695297897073!3d38.789352633634415!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e1!3m2!1sen!2slu!4v1777233673801!5m2!1sen!2slu"
          width="100%"
          height="240"
          style="border:0; display:block; margin-top:24px; border-radius:4px;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>

        <div style="display:flex; gap:12px; margin-top:32px; align-items:flex-end; opacity:0.4">
          <PineSmall height={64} color="var(--dark)" />
          <PineSmall height={48} color="var(--dark)" />
          <PineSmall height={56} color="var(--dark)" />
        </div>
      </div>
    </div>
  </div>
</section>
